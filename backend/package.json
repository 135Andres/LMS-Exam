{
  "name": "exam-generator-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "allowScripts": {
    "0": "better-sqlite3",
    "1": "bcrypt",
    "2": "esbuild",
    "bcrypt@5.1.1": true,
    "esbuild@0.28.1": true,
    "better-sqlite3@12.11.1": true
  },
  "scripts": {
    "start": "node dist/server.js",
    "start:worker": "node dist/workers/cron-entry.js",
    "dev": "tsx watch server.ts",
    "dev:worker": "tsx watch src/workers/cron-entry.ts",
    "dev:python": "cd ../backend-python && python -m uvicorn main:app --host 0.0.0.0 --port 3001 --reload",
    "dev:all": "concurrently -n py,node -c yellow,cyan \"npm run dev:python\" \"npm run dev\"",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^9.2.3",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.11.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.22.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.5.2",
    "node-cron": "^4.5.0",
    "nodemailer": "^9.0.1",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.24.2"
  }
}
