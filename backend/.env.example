# === Required ===
NINE_ROUTER_API_KEY=
NVIDIA_API_KEY_EMBEDDINGS=
JWT_SECRET=

# === Optional (defaults shown) ===
PORT=3000
NODE_ENV=development
NINE_ROUTER_BASE_URL=https://rky8wp8.abc-tunnel.us/v1
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_EMBEDDINGS_MODEL=nvidia/nv-embed-v1
NVIDIA_EMBEDDINGS_DIM=4096
EMBED_ASSISTANT_RESPONSES=true
GENERATE_MODEL=nvidia/minimaxai/minimax-m2.7
POLISH_MODEL=nvidia/deepseek-ai/deepseek-v4-flash
CHAT_MODEL=nvidia/deepseek-ai/deepseek-v4-flash
JWT_EXPIRES_IN=24h
DB_PATH=./data/database.sqlite
CORS_ORIGIN=http://localhost:3000
AUTH_SERVICE_URL=http://localhost:3001

# SMTP (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Rate limiting (optional)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_GENERATE_MAX=3
RATE_LIMIT_GENERATE_WINDOW_HOURS=1
RATE_LIMIT_OTP_MAX=3
RATE_LIMIT_OTP_WINDOW_MS=3600000
RATE_LIMIT_OTP_VERIFY_MAX=5
RATE_LIMIT_OTP_VERIFY_WINDOW_MS=60000
